# SHERPA pilot - environment template. Copy to .env and complete every value.
# Never commit .env. Reuse the API keys you already hold from earlier projects.

# ---- Deployment selector -------------------------------------------------------------
# local  : development on Linux Mint with the Docker stack and Ollama available
# cloud  : the deployed demo (Streamlit Cloud, Databricks, Solace Cloud, Aura, Qdrant Cloud)
DEPLOY_ENV=local
SHERPA_HOME=/home/pruebas/formacion/sherpa
SHERPA_PYTHON=3.12

# ---- LLMs ----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
# Local sovereign fallback (development only; not reachable from Streamlit Cloud)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ---- Embeddings (in-process) ---------------------------------------------------------
EMBED_MODEL=nomic-ai/nomic-embed-text-v1
EMBED_DIM=768

# ---- Neo4j (Aura Free in cloud) ------------------------------------------------------
NEO4J_URI=neo4j+s://XXXX.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# Local development Neo4j (Docker)
NEO4J_LOCAL_URI=bolt://localhost:7687
NEO4J_LOCAL_PASSWORD=sherpa-dev-pass

# ---- Qdrant (Cloud Free in cloud) ----------------------------------------------------
QDRANT_URL=https://XXXX.qdrant.io
QDRANT_API_KEY=
# Local development Qdrant (Docker)
QDRANT_LOCAL_URL=http://localhost:6333

# ---- Databricks (cloud free workspace) ----------------------------------------------
DATABRICKS_HOST=https://dbc-XXXXXXXX-XXXX.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/XXXXXXXXXXXX
DATABRICKS_WAREHOUSE_ID=XXXXXXXXXXXX
DATABRICKS_CATALOG=sherpa
DATABRICKS_SCHEMA=pilot
DATABRICKS_SECRET_SCOPE=sherpa

# ---- Solace (Cloud broker for the deployed demo) -------------------------------------
SOLACE_HOST=tcps://XXXX.messaging.solace.cloud:55443
SOLACE_VPN=
SOLACE_USERNAME=
SOLACE_PASSWORD=
# Local development broker (Docker)
SOLACE_LOCAL_HOST=tcp://localhost:55555
SOLACE_LOCAL_VPN=default
SOLACE_LOCAL_USERNAME=admin
SOLACE_LOCAL_PASSWORD=admin
# Which broker the mesh smoke test targets: cloud | local
SHERPA_MESH_TARGET=cloud

# ---- Observability (LangSmith free tier) ---------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sherpa

# ---- Open data sources ---------------------------------------------------------------
AEMET_API_KEY=
ORS_API_KEY=
OVERPASS_URL=https://overpass-api.de/api/interpreter
# Open-Meteo, Wikipedia, Wikidata, GBIF and iNaturalist need no key.
# A descriptive User-Agent is required by Wikipedia and OpenStreetMap policies.
HTTP_USER_AGENT=SHERPA-pilot/0.1 (contact: your-email@example.com)

# ---- GitHub --------------------------------------------------------------------------
GH_REPO=mgalanme/sherpa
GH_BRANCH=main

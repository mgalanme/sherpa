# .streamlit/secrets.toml.example
# Copy these EXACT keys into the Streamlit Community Cloud app settings (Secrets), filling in
# your values. Do not commit the real secrets.toml. These are read by load_streamlit_secrets()
# and copied into the environment so the app configuration works identically to local.

DEPLOY_ENV = "cloud"

# LLM (primary in both environments)
GROQ_API_KEY = "gsk_..."
GROQ_MODEL_PRIMARY = "llama-3.3-70b-versatile"
GROQ_MODEL_FALLBACK = "llama-3.1-8b-instant"

# Embeddings
EMBED_MODEL = "nomic-ai/nomic-embed-text-v1"
EMBED_DIM = "768"

# Neo4j Aura Free
NEO4J_URI = "neo4j+s://XXXX.databases.neo4j.io"
NEO4J_USERNAME = "neo4j"
NEO4J_PASSWORD = "..."
NEO4J_DATABASE = "neo4j"

# Qdrant Cloud Free
QDRANT_URL = "https://XXXX.qdrant.io"
QDRANT_API_KEY = "..."
QDRANT_COLLECTION = "place_facts"

# Databricks (gold tables and the audit trail)
DATABRICKS_HOST = "https://dbc-XXXXXXXX-XXXX.cloud.databricks.com"
DATABRICKS_TOKEN = "dapi..."
DATABRICKS_HTTP_PATH = "/sql/1.0/warehouses/XXXXXXXXXXXX"
DATABRICKS_CATALOG = "sherpa"
DATABRICKS_SCHEMA = "pilot"

# Solace Cloud (deployed mesh). Use tcps:// with port 55443.
SOLACE_HOST = "tcps://mr-connection-XXXX.messaging.solace.cloud:55443"
SOLACE_VPN = "sherpa-pilot"
SOLACE_USERNAME = "sherpa"
SOLACE_PASSWORD = "..."
MESH_ENABLED = "true"

# Open data
AEMET_API_KEY = "..."
ORS_API_KEY = "..."
OVERPASS_URL = "https://overpass-api.de/api/interpreter"
HTTP_USER_AGENT = "SHERPA-pilot/0.1 (contact: your-email@example.com)"
